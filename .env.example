# Convex
# Deployment used by `npx convex dev`
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=
CONVEX_RESET_TOKEN=
CONVEX_RESET_BATCH=128

# WalletConnect (RainbowKit)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# OpenAI BYOK (server-only)
OPENAI_BYOK_COOKIE_SECRET=

# Crypto.com AI Agent (server-only)
OPENAI_API_KEY=
CRONOS_TESTNET_EXPLORER_API_KEY=
CRONOS_AI_AGENT_CA_CERT=
CRONOS_AI_AGENT_INSECURE_TLS=

# Admin access (comma-separated EVM addresses)
NEXT_PUBLIC_ADMIN_WALLET_ADDRESSES=

# Cronos Testnet (public)
NEXT_PUBLIC_CRONOS_CHAIN_ID=338
NEXT_PUBLIC_CRONOS_RPC_URL=https://evm-t3.cronos.org
NEXT_PUBLIC_CRONOS_EXPLORER_BASE=https://explorer.cronos.org/testnet
NEXT_PUBLIC_CRONOS_FAUCET_URL=https://cronos.org/faucet
NEXT_PUBLIC_CRONOS_USDCE_FAUCET_URL=https://faucet.cronos.org
NEXT_PUBLIC_CRONOS_USDCE_ADDRESS=0xc01efAaF7C5C61bEbFAeb358E1161b537b8bC0e0
NEXT_PUBLIC_CROIGNITE_VAULT_ADDRESS=
NEXT_PUBLIC_BOOST_FACTORY_ADDRESS=
NEXT_PUBLIC_SPONSOR_HUB_ADDRESS=
NEXT_PUBLIC_INVOICE_RECEIPTS_ADDRESS=
NEXT_PUBLIC_BOOST_PASS_ADDRESS=
NEXT_PUBLIC_YIELD_STREAMER_ADDRESS=
NEXT_PUBLIC_BOOST_PASS_EPOCH_INTERVAL_HOURS=24

# Remotion / Diffusion
NEXT_PUBLIC_DIFFUSION_LICENSE_KEY=

# x402
X402_SELLER_WALLET=
X402_DEFAULT_AMOUNT=1000000
X402_DESCRIPTION=CroIgnite sponsorship
X402_MAX_TIMEOUT_SECONDS=300
X402_NETWORK=cronos-testnet
X402_SPONSOR_PACK_AMOUNT=250000
X402_IGNITE_PRO_AMOUNT=150000
X402_TEST_BUYER_PRIVATE_KEY=

# Logging
LOG_LEVEL=info

# Internal write secret for server->Convex mutations
CROIGNITE_INTERNAL_WRITE_SECRET=

# Vault manager (server-only)
BOOST_VAULT_MANAGER_PRIVATE_KEY=
BOOST_PASS_MANAGER_PRIVATE_KEY=

